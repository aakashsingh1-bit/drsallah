# Copy to deploy/.env on the server (never commit real secrets).
# cp .env.example .env  then fill in values.

# ─── Domains (used by Caddy for HTTPS) ───────────────────────────────────────
WEB_DOMAIN=web.drsalahalzait.me
ADMIN_DOMAIN=admin.drsalahalzait.me
API_DOMAIN=api.drsalahalzait.me
CADDY_EMAIL=you@drsalahalzait.me

# ─── Frontend build-time URLs ────────────────────────────────────────────────
VITE_API_BASE_URL=https://api.drsalahalzait.me/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
REACT_APP_API_URL=https://api.drsalahalzait.me/api/v1

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/drsallah

# ─── API runtime ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
TRUST_PROXY=1

CLIENT_URL=https://web.drsalahalzait.me
ADMIN_URL=https://admin.drsalahalzait.me
API_URL=https://api.drsalahalzait.me

JWT_SECRET=change_me_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

OTP_EXPIRES_IN=5
UNVERIFIED_USER_DELETE_AFTER_MINUTES=30

# Email (SMTP)
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_USER_EMAIL=support@example.com
SMTP_FROM_NAME=Dr. Salah Alzait Med Academy

# AWS S3 (videos + thumbnails) — leave empty in git; fill only in server .env
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=drsallah

SIGNED_URL_SECRET=change_me_signed_url_secret
SIGNED_URL_EXPIRY=3600
PLAYBACK_TOKEN_EXPIRES_IN=4h

# Video delivery (HLS adaptive + optimized MP4)
VIDEO_PROCESSING_ENABLED=true
VIDEO_HLS_ENABLED=true
VIDEO_MAX_HEIGHT=720
VIDEO_MAX_BITRATE_KBPS=1800
VIDEO_OPTIMIZE_MIN_SIZE_MB=20
VIDEO_LARGE_FILE_MB=80
VIDEO_OPTIMIZE_EXISTING_ON_STARTUP=false
VIDEO_OPTIMIZE_MAX_ATTEMPTS=3

# Stripe — publishable pk_ is OK in frontends; NEVER put sk_/whsec_ real values in git
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
