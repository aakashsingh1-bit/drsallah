{
	email {$CADDY_EMAIL}
}

# ─── Student web app ───────────────────────────────────────────────────────────
{$WEB_DOMAIN} {
	encode gzip
	reverse_proxy web:80
}

# ─── Admin panel ───────────────────────────────────────────────────────────────
{$ADMIN_DOMAIN} {
	encode gzip
	reverse_proxy admin:80
}

# ─── API + docs + Stripe webhook + video streaming ───────────────────────────
{$API_DOMAIN} {
	# Do NOT gzip API — breaks binary video streaming

	request_body {
		max_size 500MB
	}

	reverse_proxy api:5000 {
		flush_interval -1
		transport http {
			read_timeout 0
			write_timeout 0
			response_header_timeout 0
		}
	}
}
